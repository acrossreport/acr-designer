<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AcrossReportDesigner.Views"
        x:Class="AcrossReportDesigner.Views.MainWindow"
        Title="Across Report Designer ver1.0.1"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen">
	<DockPanel>
		<!-- ✅ 上部メニュー（ボタン） -->
		<Border DockPanel.Dock="Top"
                Background="#F0F0F0"
                BorderBrush="#C0C0C0"
                BorderThickness="0,0,0,1">
			<Grid Margin="6">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<!-- 左：ボタン群 -->
				<StackPanel Grid.Column="0"
				            Orientation="Horizontal"
				            Spacing="6">
					<StackPanel.Styles>
						<Style Selector="Button">
							<Setter Property="Width" Value="110"/>
							<Setter Property="Height" Value="34"/>
							<Setter Property="HorizontalContentAlignment" Value="Center"/>
							<Setter Property="VerticalContentAlignment" Value="Center"/>
							<Setter Property="FontSize" Value="14"/>
							<Setter Property="Padding" Value="6,0"/>
						</Style>
					</StackPanel.Styles>
					<Button Content="{Binding [Menu_Designer],  Source={StaticResource Loc}}"
					        Click="Designer_Click"/>
					<Button Content="{Binding [Menu_DataCreate], Source={StaticResource Loc}}"
					        Click="DataConnector_Click"/>
					<Button Content="{Binding [Menu_DataMerge], Source={StaticResource Loc}}"
					        Click="DataViewer_Click"/>
					<Button Content="{Binding [Menu_Exit],      Source={StaticResource Loc}}"
					        Click="Exit_Click"/>
				</StackPanel>
				<!-- 右端：Multilingual -->
				<StackPanel Grid.Column="2"
				            Orientation="Horizontal"
				            Spacing="6"
				            VerticalAlignment="Center">
					<TextBlock Text="{Binding [Lang_Panel_Title], Source={StaticResource Loc}}"
					           VerticalAlignment="Center"
					           FontSize="13"/>
					<ComboBox x:Name="LangCombo"
					          Width="120"
					          Height="30"
					          FontSize="13"
					          VerticalAlignment="Center"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- ✅ メイン表示領域（最後に残りを埋める） -->
		<ContentControl x:Name="MainContent"/>
	</DockPanel>
</Window>