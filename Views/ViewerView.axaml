<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="AcrossReportDesigner.Views.ViewerView">
	<DockPanel>
		<!-- =========================
             上部操作エリア
             ========================= -->
		<StackPanel DockPanel.Dock="Top"
                    Orientation="Vertical"
                    Spacing="6"
                    Margin="6">
			<!-- =========================
                 1行目：ファイル指定＋操作（固定）
                 ========================= -->
			<StackPanel Orientation="Horizontal"
            Spacing="6"
            VerticalAlignment="Center">
				<!-- テンプレート -->
				<Button Content="{Binding [Viewer_Template], Source={StaticResource Loc}}"
						Width="70"
						HorizontalContentAlignment="Center"
						Click="BrowseTemplate_Click"/>
				<TextBox x:Name="TemplatePathBox"
						 Width="300"/>
				<!-- データ -->
				<Button Content="{Binding [Viewer_Data],     Source={StaticResource Loc}}"
						Width="70"
						HorizontalContentAlignment="Center"
						Click="BrowseData_Click"/>
				<TextBox x:Name="DataPathBox"
						 Width="300"/>
				<!-- 表示 -->
				<Button x:Name="ShowButton"
						Content="{Binding [Viewer_Show],     Source={StaticResource Loc}}"
						Width="70"
						HorizontalContentAlignment="Center"
						Click="Show_Click"/>
				<!-- PDF＋フォント埋込 -->
				<Button x:Name="PdfButton"
						Content="{Binding [Viewer_PDF],      Source={StaticResource Loc}}"
						Width="70"
						HorizontalContentAlignment="Center"
						Click="Pdf_Click"/>
				<ComboBox x:Name="EmbedFontComboBox"
						  Width="90"
						  SelectedIndex="0"
						  HorizontalContentAlignment="Center">
					<ComboBoxItem Content="{Binding [Viewer_EmbedOn],  Source={StaticResource Loc}}"/>
					<ComboBoxItem Content="{Binding [Viewer_EmbedOff], Source={StaticResource Loc}}"/>
				</ComboBox>
				<!-- HTML＋出力形式 -->
				<Button x:Name="HtmlButton"
						Content="{Binding [Viewer_HTML],     Source={StaticResource Loc}}"
						Width="70"
						HorizontalContentAlignment="Center"
						Click="HtmlShow_Click"/>
				<Button x:Name="HtmlSaveButton"
						Content="{Binding [Viewer_Save],     Source={StaticResource Loc}}"
						Width="70"
						HorizontalContentAlignment="Center"
						Click="HtmlSave_Click"/>
				<ComboBox x:Name="HtmlModeComboBox"
						  Width="90"
						  SelectedIndex="0"
						  HorizontalContentAlignment="Center">
					<ComboBoxItem Content="{Binding [Viewer_ImageEmbed], Source={StaticResource Loc}}"/>
					<ComboBoxItem Content="{Binding [Viewer_CssStyle], Source={StaticResource Loc}}"/>
				</ComboBox>
				<!-- 画像埋込 クリアボタン -->
				<Button x:Name="HtmlModeClearButton"
						Content="クリア"
						Width="70"
						HorizontalContentAlignment="Center"
						Click="HtmlModeClear_Click"/>
			</StackPanel>
			<!-- =========================
                 2行目：FONT選択＋メッセージ（右端まで伸ばす）
                 ========================= -->
			<Grid VerticalAlignment="Center">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0"
                           Text="{Binding [Viewer_Font],        Source={StaticResource Loc}}"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"/>
				<ComboBox Grid.Column="1"
                          x:Name="FontComboBox"
                          Width="220"
                          SelectedIndex="0">
					<ComboBoxItem Content="{Binding [Viewer_FontDefault], Source={StaticResource Loc}}"/>
					<ComboBoxItem Content="Noto 明朝"/>
					<ComboBoxItem Content="Noto ゴシック"/>
					<ComboBoxItem Content="Noto 太字明朝"/>
					<ComboBoxItem Content="Noto 太字ゴシック"/>
				</ComboBox>
				<TextBox Grid.Column="2"
                         x:Name="MessageText"
                         Margin="12,0,0,0"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Stretch"
                         Foreground="Red"
                         IsReadOnly="True"
                         BorderThickness="1"
                         Background="White"
                         CaretBrush="Transparent"
                         TextWrapping="Wrap"
                         MinWidth="300"/>
			</Grid>
		</StackPanel>
		<!-- =========================
             プレビュー領域
             ========================= -->
		<ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
			<Image x:Name="PreviewImage"
                   Stretch="None"/>
		</ScrollViewer>
	</DockPanel>
</UserControl>
