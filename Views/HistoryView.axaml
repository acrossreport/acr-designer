<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AcrossReportDesigner.Views.HistoryView"
        Width="900"
        Height="500"
        Title="SQL履歴">

    <Grid RowDefinitions="*,Auto">

        <ListBox x:Name="HistoryList"
                 Margin="8">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4,6,4,6">
                        <!-- 1行目: 日時 + DB種別 -->
                        <TextBlock Text="{Binding SummaryLine1}"
                                   FontWeight="Bold"
                                   FontSize="12"/>
                        <!-- 2行目: 接続情報 -->
                        <TextBlock Text="{Binding SummaryLine2}"
                                   FontSize="11"
                                   Foreground="#336699"
                                   Margin="0,2,0,0"/>
                        <!-- 3行目: SQL -->
                        <TextBlock Text="{Binding SummaryLine3}"
                                   FontSize="11"
                                   Foreground="Gray"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

        <Button Grid.Row="1"
                Margin="8"
                HorizontalAlignment="Right"
                Content="選択して復元"
                Click="Select_Click"/>

    </Grid>
</Window>
